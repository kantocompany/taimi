{
  "_description": "Output schema for tool-update research agents. Write to findings/{slug}.json.",
  "_note": "The 'proposed' object is the complete tool JSON as it should look. The diff script compares it against current data, filtering out price fields (price-update's scope) and protected fields (capabilities, benchmarks).",
  "slug": "{slug}",
  "date": "{YYYY-MM-DD}",
  "status": "reviewed|changes_found|unverified",
  "source_url": "{url used for verification}",
  "fetch_method": "direct|proxy|dev_docs|web_search",
  "proposed": {
    "slug": "{slug}",
    "name": "{tool name}",
    "vendor": {
      "name": "{vendor}",
      "hq_country": "{ISO}",
      "eu_based": false,
      "pricing_url": "{url}"
    },
    "plans": [
      {
        "id": "{plan-id}",
        "name": "{Plan Name}",
        "category": "free|individual|team|enterprise|usage",
        "base_price": {
          "amount": 20.00,
          "period": "monthly",
          "per": "user"
        },
        "includes": {
          "premium_requests": null,
          "tokens_included": null,
          "notes": "terse factual notes"
        },
        "overage": null
      }
    ],
    "capabilities": {},
    "benchmarks": {}
  },
  "extraction_failures": [
    {"method": "direct", "error": "JS-rendered, no plan details in response"}
  ]
}
